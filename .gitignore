# Godot 4+ specific ignores
.godot/
.nomedia

# Godot-specific ignores
.import/
export.cfg
export_credentials.cfg
*.tmp

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# Android build artifacts (regenerable por Godot)
android/build/
client/android/build/

# Build outputs (APKs, AABs)
builds/

# Export presets (puede tener credenciales)
export_presets.cfg

# Media descargada por download_media.sh — solo va en server/, nunca en client/
client/media/images/*.jpg
client/media/audio/*.ogg
client/media/video/*.ogv

server/media/*
